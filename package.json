{
  "name": "trivia-phone-clicker",
  "version": "1.0.0",
  "description": "Phone Trivia Clicker - Monorepo Root",
  "private": true,
  "workspaces": ["server", "client", "shared"],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run start --workspace=client",
    "build:shared": "tsc --project shared/tsconfig.json",
    "build:server": "npm run build:shared && npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "test:server": "npm run test --workspace=server",
    "test": "npm run test:server"
  }
}
